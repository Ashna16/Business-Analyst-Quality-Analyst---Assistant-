# Install inside this folder (nested under OpenClaw monorepo): pnpm install --ignore-workspace
# OpenClaw gateway (Web UI + WS). Your machine used 9700; docs often use 18789.
OPENCLAW_GATEWAY_URL=http://127.0.0.1:9700
OPENCLAW_GATEWAY_TOKEN=

# Contextual AI (GLM) — preferred for meeting-note extraction; see https://docs.contextual.ai/api-reference/generate/generate
CONTEXTUAL_AI_API_KEY=
CONTEXTUAL_AI_MODEL=v2

# Parser / fallback LLM (OpenAI-compatible). Service account keys use sk-svcacct-...
OPENAI_API_KEY=
# Optional; not sent on API requests unless you extend the client.
OPENAI_PASSWORD=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Civic Nexus (PII redaction API — optional; mock uses local patterns)
CIVIC_NEXUS_API_URL=
CIVIC_NEXUS_API_KEY=

# Redis (optional — similar-bug memory). Example Redis Cloud:
# REDIS_URL=redis://default:PASSWORD@redis-XXXX.cXXX.us-east-1-X.ec2.cloud.redislabs.com:PORT
REDIS_URL=
REDIS_MEMORY_PREFIX=baqa:bugs

# Apify (Jira/Mira UI automation actor)
APIFY_API_TOKEN=
APIFY_ACTOR_ID=

# Output: Jira stub + QA markdown (default if unset: ~/Desktop/BA_QA_DEMO_OUTPUT)
# OUTPUT_DIR=./out
MEMORY_FILE=./data/bug-memory.json
# Print full JIRA-*.md and QA-*.md to terminal after each bug (default on). Set 0 to disable.
# BAQA_ECHO_ARTIFACTS=0

# Jira — browse URLs / Composio (subdomain for your-site.atlassian.net)
# JIRA_ATLASSIAN_DOMAIN=ashnaparekh1998
#
# Numeric *project id* for CreateIssueDetails?pid=… (NOT the SCRUM key). Confirm in Jira:
# Project settings → Details, or open Create Issue in SCRUM and copy `pid` from the URL.
# JIRA_PROJECT_ID=10000
# JIRA_ISSUE_TYPE_ID=1

# Composio (automated Jira via JIRA_CREATE_ISSUE) — see https://docs.composio.dev/tools/jira
# COMPOSIO_API_KEY=
# COMPOSIO_ENTITY_ID=default
# COMPOSIO_JIRA_CONNECTED_ACCOUNT_ID=
# JIRA_PROJECT_KEY=PROJ
# JIRA_ISSUE_TYPE_NAME=Bug
